# Copia este archivo a .env y ajusta los valores.
SENTIO_SECRET_KEY=cambia-esto-en-produccion-minimo-32-caracteres
SENTIO_DATABASE_URL=sqlite:///./data/sentio_local.db

# Ruta opcional al artefacto .joblib (por defecto: model/artifacts/sentio_model_v1.joblib)
# SENTIO_MODEL_ARTIFACT=C:\ruta\personalizada\sentio_model_v1.joblib

# Solo en tu PC: permite POST /dev/reset-perfil para volver al onboarding sin borrar la BD a mano.
# SENTIO_DEV_RESET=1